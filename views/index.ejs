<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-gH2yIJqKdNHPEq0n4Mqa/HGKIhSkIHeL5AyhkYV8i59U5AR6csBvApHHNl/vI1Bx"
      crossorigin="anonymous"
    />
    <title>Url Shortner</title>
  </head>
  <body>
    <div class="container">
      <h1>Url Shortner</h1>
      <!-- <form action="" method="POST" class="my-4 row g-3">
        <div class="col-auto">
          <input type="text" name="fullUrl" id="fullUrl" placeholder="URL" class="form-control-plaintext" />
          <button class="btn btn-success mb-3" type="submit">Shrink</button>
        </div>
      </form> -->

      <form class="row g-3">
        <div class="col-auto">
          <label for="fullUrl" class="visually-hidden">URL</label>
          <input type="text" class="form-control" id="fullUrl" placeholder="URL" />
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-primary mb-3">Shorten</button>
        </div>
      </form>

      <table class="table">
        <thead>
          <tr>
            <th>Full URL</th>
            <th>Short URL</th>
            <th>Clicks</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="https://google.com">https://google.com</a></td>
            <td><a href="/12345">12345</a></td>
            <td>10</td>
          </tr>
        </tbody>
      </table>
    </div>
  </body>
</html>
